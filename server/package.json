{
  "name": "brevly-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch app/server.ts",
    "build": "tsc",
    "start": "node dist/app/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@aws-sdk/client-s3": "^3.700.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.1.0",
    "kafkajs": "^2.2.4",
    "nanoid": "^5.0.9",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.3",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
